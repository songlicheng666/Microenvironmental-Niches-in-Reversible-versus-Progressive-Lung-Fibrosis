# 11. Sample-level DEG analysis (PSEUDOBULK)

fib_deg <- Fib_myo[, Fib_myo$celltype2 %in% c("GC_sensitive", "GC_low")]

counts_mat <- GetAssayData(fib_deg, assay = "Spatial", slot = "counts")

meta_deg <- fib_deg@meta.data %>%
  as.data.frame() %>%
  dplyr::select(orig.ident, group, celltype2)

meta_deg$pseudo_id <- paste(meta_deg$orig.ident, meta_deg$celltype2, sep = "__")

pseudo_ids <- unique(meta_deg$pseudo_id)

pb_counts <- sapply(pseudo_ids, function(pid) {
  cols <- rownames(meta_deg)[meta_deg$pseudo_id == pid]
  Matrix::rowSums(counts_mat[, cols, drop = FALSE])
})

pb_counts <- as.matrix(pb_counts)

pb_meta <- meta_deg %>%
  dplyr::select(orig.ident, group, celltype2, pseudo_id) %>%
  distinct() %>%
  as.data.frame()

rownames(pb_meta) <- pb_meta$pseudo_id
pb_meta <- pb_meta[colnames(pb_counts), ]

print(dim(pb_counts))
print(table(pb_meta$group, pb_meta$celltype2))

# edgeR + limma-voom
dge <- DGEList(counts = pb_counts)
keep <- filterByExpr(dge, group = pb_meta$celltype2)
dge <- dge[keep, , keep.lib.sizes = FALSE]
dge <- calcNormFactors(dge)

design <- model.matrix(~ group + celltype2, data = pb_meta)
colnames(design) <- make.names(colnames(design))
print(design)

v <- voom(dge, design, plot = TRUE)
fit <- lmFit(v, design)
fit <- eBayes(fit)

deg_gc <- topTable(
  fit,
  coef = "celltype2GC_sensitive",
  number = Inf,
  sort.by = "P"
)

deg_gc$gene <- rownames(deg_gc)
write.csv(deg_gc, file = "Pseudobulk_DEG_GC_sensitive_vs_GC_low.csv", row.names = FALSE)

deg_gc_sig <- deg_gc %>%
  filter(adj.P.Val < 0.05 & abs(logFC) > 0.5)

write.csv(deg_gc_sig, file = "Pseudobulk_DEG_GC_sensitive_vs_GC_low_sig.csv", row.names = FALSE)

