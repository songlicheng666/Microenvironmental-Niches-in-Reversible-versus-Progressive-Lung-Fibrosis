############################

fib_gc_sensitive <- Fib_myo[, Fib_myo$celltype2 == "GC_sensitive"]
counts_gc <- GetAssayData(fib_gc_sensitive, assay = "Spatial", slot = "counts")

meta_gc <- fib_gc_sensitive@meta.data %>%
  as.data.frame() %>%
  dplyr::select(orig.ident, group)

meta_gc$pseudo_id <- meta_gc$orig.ident

pseudo_ids_gc <- unique(meta_gc$pseudo_id)

pb_counts_gc <- sapply(pseudo_ids_gc, function(pid) {
  cols <- rownames(meta_gc)[meta_gc$pseudo_id == pid]
  Matrix::rowSums(counts_gc[, cols, drop = FALSE])
})

pb_counts_gc <- as.matrix(pb_counts_gc)

pb_meta_gc <- meta_gc %>%
  distinct() %>%
  as.data.frame()
rownames(pb_meta_gc) <- pb_meta_gc$pseudo_id
pb_meta_gc <- pb_meta_gc[colnames(pb_counts_gc), ]

dge_gc <- DGEList(counts = pb_counts_gc)
keep_gc <- filterByExpr(dge_gc, group = pb_meta_gc$group)
dge_gc <- dge_gc[keep_gc, , keep.lib.sizes = FALSE]
dge_gc <- calcNormFactors(dge_gc)

design_gc <- model.matrix(~ 0 + group, data = pb_meta_gc)
colnames(design_gc) <- gsub("^group", "", colnames(design_gc))

v_gc <- voom(dge_gc, design_gc, plot = TRUE)
fit_gc <- lmFit(v_gc, design_gc)

contrast_gc <- makeContrasts(
  middle_vs_early = middle - early,
  late_vs_early = late - early,
  late_vs_middle = late - middle,
  levels = design_gc
)

fit_gc2 <- contrasts.fit(fit_gc, contrast_gc)
fit_gc2 <- eBayes(fit_gc2)

deg_middle_vs_early <- topTable(fit_gc2, coef = "middle_vs_early", number = Inf)
deg_late_vs_early   <- topTable(fit_gc2, coef = "late_vs_early", number = Inf)
deg_late_vs_middle  <- topTable(fit_gc2, coef = "late_vs_middle", number = Inf)

deg_middle_vs_early$gene <- rownames(deg_middle_vs_early)
deg_late_vs_early$gene   <- rownames(deg_late_vs_early)
deg_late_vs_middle$gene  <- rownames(deg_late_vs_middle)

write.csv(deg_middle_vs_early, "Pseudobulk_DEG_GCsensitive_middle_vs_early.csv", row.names = FALSE)
write.csv(deg_late_vs_early,   "Pseudobulk_DEG_GCsensitive_late_vs_early.csv", row.names = FALSE)
write.csv(deg_late_vs_middle,  "Pseudobulk_DEG_GCsensitive_late_vs_middle.csv", row.names = FALSE)

