############################
# 14. Helper function for FeaturePlot
############################
plot_feature_umap <- function(seu, gene, cols = c("lightgrey", "blue", "red")) {
  FeaturePlot(
    seu,
    reduction = "umap",
    features = gene,
    cols = cols,
    pt.size = 1
  ) +
    theme(
      panel.border = element_rect(fill = NA, color = "black", linewidth = 0.5, linetype = "solid")
    )
}

plot_feature_spatial <- function(seu, gene, image_name = "CTD") {
  SpatialFeaturePlot(
    object = seu,
    features = gene,
    images = image_name,
    alpha = 1,
    pt.size.factor = 0.1,
    stroke = 0
  )
}

