############################
# 3. Custom function for Visium HD image
############################
ReadHD_Image <- function(image.dir,
                         image.name = "tissue_lowres_image.png",
                         filter.matrix = TRUE) {
  image <- png::readPNG(source = file.path(image.dir, image.name))
  scale.factors <- jsonlite::fromJSON(txt = file.path(image.dir, "scalefactors_json.json"))

  tissue.positions.path <- Sys.glob(paths = file.path(image.dir, "tissue_positions*"))
  tissue.positions <- arrow::read_parquet(tissue.positions.path) %>% as.data.frame()

  rownames(tissue.positions) <- tissue.positions$barcode
  tissue.positions <- tissue.positions[, -1]
  colnames(tissue.positions) <- c("tissue", "row", "col", "imagerow", "imagecol")

  if (filter.matrix) {
    tissue.positions <- tissue.positions[tissue.positions$tissue == 1, , drop = FALSE]
  }

  unnormalized.radius <- scale.factors$fiducial_diameter_fullres * scale.factors$tissue_lowres_scalef
  spot.radius <- unnormalized.radius / max(dim(image))

  new(
    Class = "VisiumV1",
    image = image,
    scale.factors = scalefactors(
      spot = scale.factors$tissue_hires_scalef,
      fiducial = scale.factors$fiducial_diameter_fullres,
      hires = scale.factors$tissue_hires_scalef,
      lowres = scale.factors$tissue_lowres_scalef
    ),
    coordinates = tissue.positions,
    spot.radius = spot.radius
  )
}

############################
# 4. Custom function for loading Visium HD Seurat object
############################
Load10X_HD <- function(data.dir,
                       filename = "filtered_feature_bc_matrix.h5",
                       assay = "Spatial",
                       slice = "slice1",
                       filter.matrix = TRUE,
                       to.upper = FALSE,
                       image = NULL) {
  if (length(data.dir) > 1) {
    warning("'Load10X_HD' accepts only one 'data.dir'", immediate. = TRUE)
    data.dir <- data.dir[1]
  }

  data <- Read10X_h5(filename = file.path(data.dir, filename))

  if (to.upper) {
    rownames(data) <- toupper(rownames(data))
  }

  object <- CreateSeuratObject(counts = data, assay = assay)

  if (is.null(image)) {
    image <- ReadHD_Image(
      image.dir = file.path(data.dir, "spatial"),
      filter.matrix = filter.matrix
    )
  } else {
    if (!inherits(image, "VisiumV1")) {
      stop("Image must be an object of class 'VisiumV1'.")
    }
  }

  image <- image[Cells(object)]
  DefaultAssay(image) <- assay
  object[[slice]] <- image

  return(object)
}

############################
# 5. QC function
############################
scQCSpatial <- function(seu) {
  seu$log10GenesPerUMI <- log10(seu$nFeature_Spatial) / log10(seu$nCount_Spatial)

  mito_genes <- rownames(seu)[grep("^MT-", rownames(seu))]
  message("Mito genes detected: ", length(mito_genes))
  seu <- PercentageFeatureSet(seu, pattern = "^MT-", col.name = "percent.mt")

  ribo_genes <- rownames(seu)[grep("^RP[SL]", rownames(seu), ignore.case = TRUE)]
  message("Ribo genes detected: ", length(ribo_genes))
  seu <- PercentageFeatureSet(seu, pattern = "^RP[SL]", col.name = "percent.ribo")

  hb_genes <- rownames(seu)[grep("^HB[^(P)]", rownames(seu), ignore.case = TRUE)]
  message("HB genes detected: ", length(hb_genes))
  seu <- PercentageFeatureSet(seu, pattern = "^HB[^(P)]", col.name = "percent.hb")

  return(seu)
}

