# 假设你的原始Seurat对象名为`seurat_obj`
# 你的特定barcodes列表

selected_barcodes <- read.csv(file = "E:/机化性肺炎空间转录组/初步分析代码/选择区域/CTRL/55M/re-cluster55m2.csv")  # 替换为你的100个barcodes
selected_barcodes <- selected_barcodes$Barcode 
# 使用subset函数提取特定的barcodes
new_seurat_obj <- subset(CRC.qc, cells = selected_barcodes)
new_seurat_obj <- RunUMAP(new_seurat_obj, reduction = "pca", dims = 1:15) %>% 
  FindNeighbors(reduction = "pca", dims = 1:15) %>% 
  FindClusters(verbose = FALSE)
# 生成基本的 SpatialDimPlot
p <- SpatialDimPlot(new_seurat_obj, alpha = c(1, 1), group.by = "seurat_clusters", shape = 21, label = F)
# 提取数据和颜色信息
data <- p$data
colors <- data$seurat_clusters
# 使用RColorBrewer中的地中海配色
med_palette <- colorRampPalette(brewer.pal(12, "Set3"))(length(unique(colors)))
# 创建新的 ggplot 对象
p_new <- ggplot(data, aes(x = x, y = y, fill = colors)) +
  geom_point(shape = 21, size = 2, alpha = 1, stroke = 0) +  # stroke = 0 去除边框
  scale_fill_manual(values = med_palette) +
  theme_minimal() +
  theme(legend.position = "right") 
p_new
